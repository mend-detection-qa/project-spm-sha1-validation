{
  "description": "SHA1 checksum validation for Swift SPM packages (TKA-10186)",
  "version": 1.7,

  "base_config": {
    "validate_scan_output": true,
    "scan_output": {
      "_security_scan_report_conclusion": "success",
      "total_libs_scanned": {"gte": 4},
      "expected_messages": []
    },

    "validate_dependency_tree": true,
    "dependency_tree": {
      "check_dependency_tree_detection_status": true,
      "check_update_request_sca_results": false,

      "expected_total_dependencies_number": {"gte": 4},
      "expected_direct_dependencies_number": {"eq": 4},
      "expected_transitive_dependencies_number": {"gte": 0},

      "direct_dependencies_names_list": {
        "contains": [
          "braintree_ios",
          "promises",
          "Hero",
          "SDWebImage"
        ]
      },
      "transitive_dependencies_names_list": {"contains": []},

      "expected_package_managers": {
        "contains": ["swift"]
      },

      "validate_agent_versions": true,
      "expected_agent_version": "",
      "expected_plugin_version": "",
      "validate_mend_tags": false,

      "validate_checksums": true,
      "_comment_validate_checksums": "SHA1 values from Mend Index (TKA-10186 comment 279760 by Maria Korlotian). If scanner SHA1 != Index SHA1, packages show as unmatched in Core UI.",
      "checksums_config": {
        "check_sha1_not_empty": true,
        "check_sha1_format": true,
        "check_sha1_consistency": true,
        "check_checksums_by_formula": true,
        "expected_dependency_checksums": [
          {
            "_comment": "Index SHA1 confirmed by Maria. Scanner was sending dba470388d4fd735bcd01de5da9fdb194000aae1 (wrong)",
            "artifactId": "braintree_ios",
            "version": "6.23.3",
            "expected_sha1": "dba470388d4fd735bcd01de5da9fdb194000aae1"
          },
          {
            "_comment": "Index SHA1 confirmed. Scanner was sending d5be14bca7ea3548a87c09dec6645664e252ccfa (wrong)",
            "artifactId": "promises",
            "version": "2.4.0",
            "expected_sha1": "d5be14bca7ea3548a87c09dec6645664e252ccfa"
          },
          {
            "_comment": "Index SHA1 confirmed. Scanner was sending 2b793e3789f52592115e661504f747f5847f91ba (wrong)",
            "artifactId": "Hero",
            "version": "1.6.1",
            "expected_sha1": "2b793e3789f52592115e661504f747f5847f91ba"
          },
          {
            "_comment": "Index SHA1 confirmed. Scanner was sending 34108a1320537faebca7473d51c7f4be6a3ed6a0 (wrong)",
            "artifactId": "SDWebImage",
            "version": "5.21.3",
            "expected_sha1": "34108a1320537faebca7473d51c7f4be6a3ed6a0"
          }
        ]
      }
    },

    "validate_vulnerabilities_table": true,
    "vulnerabilities_table": {
      "check_vulnerabilities_table_structure": true,
      "expected_total_vulnerabilities_number": {"gte": 0},
      "vulnerabilities_ids_list": {"contains": []},
      "vulnerabilities_names_list": {"contains": []}
    },

    "validate_scanner_logs": false,
    "logs": {
      "check_scanner_logs": true,
      "detect_secrets": false,
      "expected_log_lines": []
    },

    "validate_reachability": false,
    "reachability": {
      "check_reachability_status": true,
      "validate_issues": false,
      "expected_reachable_cves": {"contains": []},
      "expected_unreachable_cves": {"contains": []},
      "expected_reachable_libraries": {"contains": []},
      "expected_unreachable_libraries": {"contains": []},
      "expected_total_reachable_count": {"gte": 0},
      "expected_total_unreachable_count": {"gte": 0},
      "expected_reachability_traces": []
    },

    "validate_project_contributors": true,
    "contributors": {
      "check_contributors_structure": true,
      "expected_contributors": [],
      "expected_min_commits": {"gte": 1},
      "expected_total_contributors": {}
    }
  }
}
